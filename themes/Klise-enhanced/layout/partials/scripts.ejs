
<% if (theme.scripts !== undefined && theme.scripts.length > 0) { %>
    <% theme.scripts.forEach(url => { %>
      <script src="<%= url_for(url) %>"></script>
    <% }); %>
  <% } %>
  <script src="https://cdn.jsdelivr.net/npm/pjax@0.2.8/pjax.js"></script>
  <script>
    var pjax = new Pjax({
      elements: 'a.menu-link, a[href^="/"]:not([target="_blank"])',
      selectors: ['#pjax-container', 'title']
    });
    document.addEventListener('pjax:success', function() {
      // re-apply highlight data-lang after pjax swap
      document.querySelectorAll('figure.highlight').forEach(function(item) {
        var langName = item.getAttribute('class').split(' ')[1];
        if (langName === 'plain' || langName === undefined) langName = 'Code';
        item.setAttribute('data-lang', langName);
      });
    });
  </script>
  <script>
  // Smooth blue rain - performance optimized
  (function() {
    var canvas = document.getElementById('rain-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var W, H;
    var drops = [];
    var TOTAL = 90;

    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    function newDrop() {
      return {
        x: Math.random() * W,
        y: Math.random() * -H,
        w: 1 + Math.random() * 2.2,     // width
        h: 6 + Math.random() * 14,      // height
        speed: 1.5 + Math.random() * 2.5, // slow fall
        alpha: 0.25 + Math.random() * 0.35,
        swayRate: 0.01 + Math.random() * 0.02,
        swayAmp: 0.3 + Math.random() * 0.8,
        swayOff: Math.random() * Math.PI * 2
      };
    }

    for (var i = 0; i < TOTAL; i++) {
      var d = newDrop();
      d.y = Math.random() * H;
      drops.push(d);
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      var isDark = document.body.getAttribute('data-theme') === 'dark';
      var color = isDark ? '130,195,230' : '70,145,210';

      for (var i = 0; i < drops.length; i++) {
        var d = drops[i];
        d.y += d.speed;
        d.x += Math.sin(d.swayOff + d.y * d.swayRate) * d.swayAmp;

        if (d.y > H + 20) {
          var nd = newDrop();
          // inherit position from existing but start from top
          drops[i] = nd;
          d = nd;
        }

        // Draw elongated rounded drop
        ctx.fillStyle = 'rgba(' + color + ',' + d.alpha + ')';
        ctx.beginPath();
        var rx = d.w / 2;
        var ry = d.h / 2;
        ctx.ellipse(d.x, d.y, rx, ry, 0, 0, Math.PI * 2);
        ctx.fill();
      }
      requestAnimationFrame(draw);
    }

    draw();
  })();
  </script>