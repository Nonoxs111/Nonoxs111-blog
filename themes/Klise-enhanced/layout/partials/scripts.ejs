
<% if (theme.scripts !== undefined && theme.scripts.length > 0) { %>
    <% theme.scripts.forEach(url => { %>
      <script src="<%= url_for(url) %>"></script>
    <% }); %>
  <% } %>
  <script src="https://cdn.jsdelivr.net/npm/pjax@0.2.8/pjax.js"></script>
  <script>
    var pjax = new Pjax({
      elements: 'a.menu-link, a[href^="/"]:not([target="_blank"])',
      selectors: ['#pjax-container', 'title']
    });
    document.addEventListener('pjax:success', function() {
      // re-apply highlight data-lang after pjax swap
      document.querySelectorAll('figure.highlight').forEach(function(item) {
        var langName = item.getAttribute('class').split(' ')[1];
        if (langName === 'plain' || langName === undefined) langName = 'Code';
        item.setAttribute('data-lang', langName);
      });
      // update active menu link
      var currentPath = window.location.pathname.replace(/\/$/, '') || '/';
      document.querySelectorAll('.menu-link').forEach(function(link) {
        var href = link.getAttribute('href').replace(/\/$/, '') || '/';
        if (href === currentPath) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
    });
  </script>
  <script>
  // Blue rain droplet canvas
  (function() {
    var canvas = document.getElementById('rain-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var W, H;
    var drops = [];
    var DROP_COUNT = 80;

    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    function randomDrop() {
      return {
        x: Math.random() * W,
        y: Math.random() * -H,
        r: 2 + Math.random() * 4,
        speed: 6 + Math.random() * 10,
        opacity: 0.15 + Math.random() * 0.25,
        sway: (Math.random() - 0.5) * 1.5
      };
    }

    for (var i = 0; i < DROP_COUNT; i++) {
      var d = randomDrop();
      d.y = Math.random() * H;
      drops.push(d);
    }

    function drawDrop(drop) {
      ctx.save();
      ctx.translate(drop.x, drop.y);
      ctx.beginPath();
      // teardrop shape
      ctx.moveTo(0, -drop.r * 2);
      ctx.bezierCurveTo(drop.r, -drop.r, drop.r, 0, 0, drop.r);
      ctx.bezierCurveTo(-drop.r, 0, -drop.r, -drop.r, 0, -drop.r * 2);
      ctx.closePath();
      var isDark = document.body.getAttribute('data-theme') === 'dark';
      var color = isDark ? '100, 180, 220' : '80, 160, 210';
      ctx.fillStyle = 'rgba(' + color + ',' + drop.opacity + ')';
      ctx.fill();
      ctx.restore();
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      for (var i = 0; i < drops.length; i++) {
        var drop = drops[i];
        drop.y += drop.speed;
        drop.x += drop.sway;
        if (drop.y > H + 20) {
          drops[i] = randomDrop();
        }
        drawDrop(drop);
      }
      requestAnimationFrame(draw);
    }

    draw();
  })();
  </script>
  <script>
  // Navbar scroll effect - throttled
  (function() {
    var navbar = document.querySelector('.navbar');
    if (!navbar) return;
    var isScrolled = false;
    var ticking = false;
    function update() {
      var y = window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0;
      var shouldScroll = y > 10;
      if (shouldScroll !== isScrolled) {
        isScrolled = shouldScroll;
        navbar.classList.toggle('scrolled', shouldScroll);
      }
      ticking = false;
    }
    window.addEventListener('scroll', function() {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
  })();
  </script>