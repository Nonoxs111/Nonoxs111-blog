
<% if (theme.scripts !== undefined && theme.scripts.length > 0) { %>
    <% theme.scripts.forEach(url => { %>
      <script src="<%= url_for(url) %>"></script>
    <% }); %>
  <% } %>
  <script src="https://cdn.jsdelivr.net/npm/pjax@0.2.8/pjax.js"></script>
  <script>
    var pjax = new Pjax({
      elements: 'a.menu-link, a[href^="/"]:not([target="_blank"])',
      selectors: ['#pjax-container', 'title']
    });
    document.addEventListener('pjax:success', function() {
      // re-apply highlight data-lang after pjax swap
      document.querySelectorAll('figure.highlight').forEach(function(item) {
        var langName = item.getAttribute('class').split(' ')[1];
        if (langName === 'plain' || langName === undefined) langName = 'Code';
        item.setAttribute('data-lang', langName);
      });
    });
  </script>
  <script>
  // Layered blue rain with gradient droplets
  (function() {
    var canvas = document.getElementById('rain-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var W, H;
    var drops = [];

    // Three layers: far (index 0), mid (1), near (2)
    var LAYERS = [
      { count: 60, rMin: 0.5, rMax: 1.5, speedMin: 3,  speedMax: 6,  alphaMin: 0.08, alphaMax: 0.15, sway: 0.3 },
      { count: 50, rMin: 1.5, rMax: 3.0, speedMin: 6,  speedMax: 10, alphaMin: 0.15, alphaMax: 0.28, sway: 0.6 },
      { count: 30, rMin: 3.0, rMax: 5.0, speedMin: 8,  speedMax: 14, alphaMin: 0.2,  alphaMax: 0.4,  sway: 1.0 }
    ];

    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    function randomDrop(layer) {
      return {
        x: Math.random() * W,
        y: Math.random() * -H,
        r: layer.rMin + Math.random() * (layer.rMax - layer.rMin),
        speed: layer.speedMin + Math.random() * (layer.speedMax - layer.speedMin),
        alpha: layer.alphaMin + Math.random() * (layer.alphaMax - layer.alphaMin),
        sway: layer.sway,
        swayOffset: Math.random() * Math.PI * 2
      };
    }

    LAYERS.forEach(function(layer) {
      for (var i = 0; i < layer.count; i++) {
        var d = randomDrop(layer);
        d.y = Math.random() * H;
        d._layer = layer;
        drops.push(d);
      }
    });

    function drawDrop(drop) {
      ctx.save();
      ctx.translate(drop.x, drop.y);
      var isDark = document.body.getAttribute('data-theme') === 'dark';

      // Gradient: lighter at top, deeper at bottom
      var r = drop.r;
      var topAlpha = drop.alpha * 0.5;
      var botAlpha = drop.alpha;
      var gradient = ctx.createLinearGradient(0, -r * 2.5, 0, r);
      var c1, c2;
      if (isDark) {
        c1 = 'rgba(150,210,240,' + topAlpha + ')';
        c2 = 'rgba(60,140,200,' + botAlpha + ')';
      } else {
        c1 = 'rgba(160,215,240,' + topAlpha + ')';
        c2 = 'rgba(50,120,190,' + botAlpha + ')';
      }
      gradient.addColorStop(0, c1);
      gradient.addColorStop(1, c2);

      ctx.beginPath();
      // Teardrop shape
      ctx.moveTo(0, -r * 2.5);
      ctx.bezierCurveTo(r * 0.8, -r, r * 0.8, r * 0.3, 0, r);
      ctx.bezierCurveTo(-r * 0.8, r * 0.3, -r * 0.8, -r, 0, -r * 2.5);
      ctx.closePath();
      ctx.fillStyle = gradient;
      ctx.fill();

      // Tiny highlight spot at top
      ctx.beginPath();
      ctx.arc(0, -r * 1.5, r * 0.25, 0, Math.PI * 2);
      ctx.fillStyle = isDark ? 'rgba(200,230,255,' + (drop.alpha * 0.7) + ')' : 'rgba(220,240,255,' + (drop.alpha * 0.7) + ')';
      ctx.fill();

      ctx.restore();
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      for (var i = 0; i < drops.length; i++) {
        var drop = drops[i];
        drop.y += drop.speed;
        drop.x += Math.sin(drop.swayOffset + drop.y * 0.03) * drop.sway;
        if (drop.y > H + 30) {
          var oldLayer = drop._layer;
          var nd = randomDrop(oldLayer);
          // Preserve the layer reference
          nd._layer = oldLayer;
          drops[i] = nd;
          drop = nd;
        }
        drawDrop(drop);
      }
      requestAnimationFrame(draw);
    }

    draw();
  })();
  </script>